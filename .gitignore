# macOS
.DS_Store
.AppleDouble
.LSOverride

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
dist/
*.egg-info/

# Jupyter
.ipynb_checkpoints/

# KG databases — all regenerable build artifacts, not tracked in git
/.dockg/
/.codekg/
/.ftreekg/
/.agentkg/
**/.dockg/graph.sqlite

# SQLite transient files (WAL/SHM are runtime-only, can exceed GitHub's 100MB limit)
*.sqlite-wal
*.sqlite-shm

# LanceDB — entire vector index is local-only; rebuild with `dockg build` after clone
**/.dockg/lancedb/
**/.dockg/lancedb-bench*/
